           <item>
            <widget class="QCheckBox" name="ckb_saveImg">
             <property name="styleSheet">
              <string notr="true">QCheckBox {
    spacing: 8px;
    font-size: 20px;
    font-weight: bold;
    color: rgb(0, 0, 0);
}

/* 未选中状态 */
QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border: 2px solid #999;
    border-radius: 4px;      /* 方形圆角，可改成 10px 做更圆润风格 */
    background: #ffffff;
}

/* 悬停效果 */
QCheckBox::indicator:hover {
    border: 2px solid #666;
}

/* 按下效果 */
QCheckBox::indicator:pressed {
    border: 2px solid #1565C0;
    background-color: #E3F2FD;
}

/* 选中状态 */
QCheckBox::indicator:checked {
    border: 2px solid #2196F3;
    background-color: #2196F3;
    image: none; /* 不使用默认勾选图 */
}

/* 选中时绘制“勾”效果（用渐变模拟） */
QCheckBox::indicator:checked {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #2196F3,
        stop:1 #1E88E5
    );
}

/* 半选状态（例如父子联动时） */
QCheckBox::indicator:indeterminate {
    border: 2px solid #2196F3;
    background-color: #BBDEFB;
}

/* 禁用状态 */
QCheckBox::indicator:disabled {
    border: 2px solid #ccc;
    background: #eee;
}

QCheckBox:disabled {
    color: #999;
}

/* 选中时文字 */
QCheckBox:checked {
    color: #2196F3;
    font-weight: 500;
}</string>
