     <item>
      <widget class="QTabWidget" name="tabWidget">
       <property name="styleSheet">
        <string notr="true">QTabWidget::pane {
    border: 1px solid #DDD;
    border-radius: 4px;
    background: #F8F8F8;
}

QTabBar::tab {
    font: bold 14px;
    color: #666;
    background: #F8F8F8;
    border: 1px solid #DDD;
    border-bottom: none; /* 让选中tab和pane连起来 */
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    padding: 5px 15px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background: #FFF;
    color: #333;
    border-color: #AAA;
}

QTabBar::tab:!selected {
    background: #F8F8F8;
    color: #666;
}

QTabBar::tab:hover {
    background: #EEE;
}</string>
       </property>
