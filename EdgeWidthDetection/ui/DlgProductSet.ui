    color: #444;
	font-size:20px;
}

QPushButton:hover {
    border-color: #999;
    background-color: #F5F5F5;
}

QPushButton:pressed {
    border-color: #777;
    background-color: #EEE;
}</string>
                       </property>
                       <property name="text">
                        <string>value</string>
                       </property>
                      </widget>
